modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mockup Preview Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Portfolio Dev"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Swiss Portfolio"

[[workflows.workflow]]
name = "Mockup Preview Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5174 BASE_PATH=/__mockup pnpm --filter @workspace/mockup-sandbox run dev"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Portfolio Dev"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=21113 BASE_PATH=/ pnpm --filter @workspace/portfolio run dev"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Swiss Portfolio"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 BASE_PATH=/swiss-portfolio/ pnpm --filter @workspace/swiss-portfolio run dev"

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[nix]
channel = "stable-25_05"
